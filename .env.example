# =============================================================================
#  World of Buoys — environment. Copy to .env and fill in CHANGE_ME values.
#  This stack connects to your EXISTING Kafka and CouchDB. Inside a container,
#  "localhost" is the container itself — use the LAN IP/hostname of the box
#  that runs each service.
# =============================================================================

# ---- Kafka (your existing brokers) -----------------------------------------
KAFKA_BOOTSTRAP_SERVERS=CHANGE_ME:9092        # e.g. 192.168.1.20:9092 or b1:9092,b2:9092
KAFKA_OBSERVATIONS_TOPIC=buoy.observations
KAFKA_STATIONS_TOPIC=buoy.stations
KAFKA_CONSUMER_GROUP=world-of-buoys-sink
KAFKA_CLIENT_ID=world-of-buoys
# Security: PLAINTEXT (default) | SASL_PLAINTEXT | SASL_SSL | SSL
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=                         # PLAIN | SCRAM-SHA-256 | SCRAM-SHA-512 (if SASL)
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SSL_CA_LOCATION=                        # path to CA cert (if SSL)

# ---- CouchDB (your existing instance) --------------------------------------
COUCHDB_URL=http://CHANGE_ME:5984             # e.g. http://192.168.1.21:5984
COUCHDB_DATABASE=world_of_buoys
COUCHDB_USER=CHANGE_ME
COUCHDB_PASSWORD=CHANGE_ME

# ---- Ingestion (scrape NDBC -> Kafka) --------------------------------------
INGEST_INTERVAL_SECONDS=1800                  # re-scrape realtime data (NDBC updates ~hourly)
STATION_TABLE_REFRESH_SECONDS=86400           # refresh station metadata table daily
INGEST_STATION_FILTER=                        # comma-sep station ids to limit (testing); blank = all
INGEST_MAX_CONCURRENCY=16                     # parallel realtime2 fetches

# ---- API behaviour ----------------------------------------------------------
SNAPSHOT_TTL_SECONDS=60                       # cache the all-stations snapshot this long
FRESH_WINDOW_HOURS=24                         # a station is "reporting" if newer than this
CORS_ALLOW_ORIGINS=                           # leave blank in prod (same-origin via nginx)

# ---- Web --------------------------------------------------------------------
WEB_PORT=8080                                 # host port the UI is served on

# ---- Cloudflare Tunnel (optional) ------------------------------------------
# Start with: docker compose --profile tunnel up -d
# Get your token from: dash.cloudflare.com -> Zero Trust -> Networks -> Tunnels
CLOUDFLARE_TUNNEL_TOKEN=
